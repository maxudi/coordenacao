# ─── Variáveis de ambiente ───────────────────────────────────────────────────
# Copie este arquivo como .env.local para desenvolvimento local
# No EasyPanel configure estas variáveis em: App > Environment Variables

# URL do Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anon pública do Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Chave service_role do Supabase — usada nas rotas de API server-side (obrigatório)
# ⚠️  NUNCA exponha esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
